# ═══════════════════════════════════════════════════════════════════
#  EDA on AWS — 환경별 설정 예시 (example.env)
# ═══════════════════════════════════════════════════════════════════
#
# 이 파일을 복사해서 환경별 설정을 만드세요:
#   cp config/example.env config/prod.env
#   $EDITOR config/prod.env
#
# 배포:
#   CONFIG=config/prod.env ./setup.sh
# ═══════════════════════════════════════════════════════════════════


# ─── 예시 1: 풀 구성 (OpenZFS + ONTAP + License Server) ────────────

REGION="ap-northeast-2"
CLUSTER_NAME="eda-prod"

# CDK 스택 접두사 — 여러 환경을 같은 계정에 두려면 다르게 설정
# 예: STACK_PREFIX="EdaProd" → EdaProdBase, EdaProdStorage, EdaProdLicenseServer
STACK_PREFIX="Eda"

VPC_ID="vpc-xxxxxxxxxxxxxxxxx"
SUBNET_ID="subnet-xxxxxxxxxxxxxxxxx"

ENABLE_OPENZFS=1
OPENZFS_SIZE_GIB=20480      # 20 TiB
OPENZFS_THROUGHPUT=5120     # 5120 MBps

ENABLE_ONTAP=1
ONTAP_SIZE_GIB=40960        # 40 TiB
ONTAP_TPUT_PER_HA=6144      # 6144 MBps per HA pair
ONTAP_HA_PAIRS=2            # 총 12 GBps / 400K IOPS

ENABLE_LICENSE_SERVER=1
LICENSE_INSTANCE_TYPE="m7i.large"

ENABLE_LOGIN_NODE=1
ENABLE_SSM=1

ENABLE_VPC_ENDPOINTS=1

ALARM_EMAIL="ops-team@example.com"


# ─── 예시 2: 최소 구성 (OpenZFS만, on-prem license server 재사용) ──
#
# CLUSTER_NAME="eda-dev"
# ENABLE_OPENZFS=1
# OPENZFS_SIZE_GIB=10240
# OPENZFS_THROUGHPUT=1280
# ENABLE_ONTAP=0
# ENABLE_LICENSE_SERVER=0       # ← on-prem 재사용
# ENABLE_LOGIN_NODE=1


# ─── 예시 3: Login Node 없이 on-prem 직접 submission ───────────────
#
# ENABLE_LOGIN_NODE=0
# # 주의: on-prem Slurm client + same munge.key + matching UID 필요
