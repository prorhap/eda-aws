# ═══════════════════════════════════════════════════════════════════
#  EDA on AWS — Per-environment configuration examples (example.env)
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to create an environment-specific config:
#   cp config/example.env config/prod.env
#   $EDITOR config/prod.env
#
# Deploy:
#   CONFIG=config/prod.env ./setup.sh
# ═══════════════════════════════════════════════════════════════════


# ─── Example 1: Full configuration (OpenZFS + ONTAP + License Server) ──

REGION="ap-northeast-2"
CLUSTER_NAME="eda-prod"

# CDK stack prefix — use different values to deploy multiple environments in the same account
# e.g. STACK_PREFIX="EdaProd" → EdaProdBase, EdaProdStorage, EdaProdLicenseServer
STACK_PREFIX="Eda"

VPC_ID="vpc-xxxxxxxxxxxxxxxxx"
SUBNET_ID="subnet-xxxxxxxxxxxxxxxxx"

ENABLE_OPENZFS=1
OPENZFS_SIZE_GIB=20480      # 20 TiB
OPENZFS_THROUGHPUT=5120     # 5120 MBps

ENABLE_ONTAP=1
ONTAP_SIZE_GIB=40960        # 40 TiB
ONTAP_TPUT_PER_HA=6144      # 6144 MBps per HA pair
ONTAP_HA_PAIRS=2            # total 12 GBps / 400K IOPS

ENABLE_LICENSE_SERVER=1
LICENSE_INSTANCE_TYPE="m7i.large"

ENABLE_LOGIN_NODE=1
ENABLE_SSM=1

ENABLE_VPC_ENDPOINTS=1

ALARM_EMAIL="ops-team@example.com"


# ─── Example 2: Minimal configuration (OpenZFS only, reuse on-prem license server) ──
#
# CLUSTER_NAME="eda-dev"
# ENABLE_OPENZFS=1
# OPENZFS_SIZE_GIB=10240
# OPENZFS_THROUGHPUT=1280
# ENABLE_ONTAP=0
# ENABLE_LICENSE_SERVER=0       # ← reuse on-prem license server
# ENABLE_LOGIN_NODE=1


# ─── Example 3: Direct submission from on-prem without Login Node ──
#
# ENABLE_LOGIN_NODE=0
# # Note: requires on-prem Slurm client + same munge.key + matching UID
