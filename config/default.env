# ═══════════════════════════════════════════════════════════════════
#  EDA on AWS — Default deployment configuration (default.env)
# ═══════════════════════════════════════════════════════════════════
#
# Loaded automatically by setup.sh.
# To use a different config file:
#   CONFIG=config/prod.env ./setup.sh
#
# Individual values can be overridden via environment variables (env takes precedence):
#   VPC_ID=vpc-xxx ./setup.sh
#
# All values use bash shell syntax. Comments start with #, strings use quotes.
# ═══════════════════════════════════════════════════════════════════


# ─── AWS basics ────────────────────────────────────────────────────
REGION="ap-northeast-2"
CLUSTER_NAME="hpc-cluster"

# CDK stack prefix — e.g. Eda → EdaBase, EdaStorage, EdaLicenseServer
# Use different prefixes to deploy multiple environments (dev/prod) in the same account (e.g. EdaDev, EdaProd)
STACK_PREFIX="Eda"


# ─── Existing VPC / Subnet (required) ─────────────────────────────
# CDK imports existing resources rather than creating a new VPC/Subnet.
# Fill in the actual VPC/Subnet IDs below,
# or override via env at runtime:
#   VPC_ID=vpc-xxx SUBNET_ID=subnet-xxx ./setup.sh
VPC_ID=""
SUBNET_ID=""


# ─── FSx for OpenZFS (enabled by default, high-performance NVMe L2ARC) ─
ENABLE_OPENZFS=1
# Capacity: 64 ~ 524288 GiB (512 TiB). Default 10 TiB.
OPENZFS_SIZE_GIB=320
# Throughput (MBps). Allowed values: 160 / 320 / 640 / 1280 / 2560 / 3840 / 5120 / 7680 / 10240
OPENZFS_THROUGHPUT=1280


# ─── FSx for NetApp ONTAP (disabled by default) ─────────────────────
# Enable when storage efficiency, per-file auditing, or SnapMirror is required.
ENABLE_ONTAP=0
# Capacity: 1024 ~ 1048576 GiB (1 PiB). Max 512 TiB per HA pair.
ONTAP_SIZE_GIB=10240
# Throughput per HA pair (MBps). Allowed values: 1536 / 3072 / 6144
ONTAP_TPUT_PER_HA=3072
# Number of HA pairs. 1 ~ 12. Each pair = 6 GBps / 200K IOPS.
ONTAP_HA_PAIRS=1


# ─── License Server (enabled by default) ──────────────────
ENABLE_LICENSE_SERVER=1
LICENSE_INSTANCE_TYPE="m7i.large"


# ─── Cluster topology ──────────────────────────────────────────────
# Whether to create a Login Node pool (for Verdi GUI / DCV).
# 1: Create a ParallelCluster LoginNodes pool (multi-user entry point behind ALB) — default/recommended
# 0: Submit jobs directly from on-prem (requires Slurm client + munge.key sync)
ENABLE_LOGIN_NODE=1

# Enable SSM Session Manager access.
ENABLE_SSM=0


# ─── Auto-create VPC Endpoints ────────────────────────────────────
# CDK automatically creates VPC endpoints required by ParallelCluster.
# Endpoints that already exist are skipped.
# logs / cloudformation / ec2 / s3 / dynamodb + (elb / asg if LoginNode=1)
ENABLE_VPC_ENDPOINTS=1


# ─── Optional ──────────────────────────────────────────────────────
# Email address for CloudWatch alarm notifications.
# ALARM_EMAIL=""

# To run only specific steps:
# SKIP_CDK=0                     # Set to 1 to skip CDK deployment (when outputs.json already exists)
# SKIP_CLUSTER=0                 # Set to 1 to skip pcluster creation (generates config file only)
# SKIP_CONNECTIVITY_CHECK=0      # Set to 1 to bypass subnet connectivity pre-check
