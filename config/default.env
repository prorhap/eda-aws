# ═══════════════════════════════════════════════════════════════════
#  EDA on AWS — 기본 배포 설정 (default.env)
# ═══════════════════════════════════════════════════════════════════
#
# setup.sh / setup-from-cloudshell.sh가 자동으로 이 파일을 로드합니다.
# 다른 설정 파일을 쓰려면:
#   CONFIG=config/prod.env ./setup.sh
#
# 개별 값은 환경변수로 override 가능합니다 (env 우선):
#   VPC_ID=vpc-xxx ./setup.sh
#
# 모든 값은 bash shell syntax입니다. 주석은 #, 문자열은 따옴표 사용.
# ═══════════════════════════════════════════════════════════════════


# ─── AWS basics ────────────────────────────────────────────────────
REGION="ap-northeast-2"
CLUSTER_NAME="hpc-cluster"

# CDK 스택 접두사 — 예: Eda → EdaBase, EdaStorage, EdaLicenseServer
# 여러 환경(dev/prod)을 같은 계정에 두려면 접두사를 다르게 설정 (예: EdaDev, EdaProd)
STACK_PREFIX="Eda"


# ─── 기존 VPC / Subnet (필수) ──────────────────────────────────────
# CDK는 VPC/Subnet을 새로 만들지 않고 기존 자원을 import합니다.
# 아래 값을 실제 VPC/Subnet ID로 채워주세요.
# 또는 setup.sh 실행 시 env로 override:
#   VPC_ID=vpc-xxx SUBNET_ID=subnet-xxx ./setup.sh
VPC_ID=""
SUBNET_ID=""


# ─── FSx for OpenZFS (기본 활성, NVMe L2ARC 고성능) ────────────────
ENABLE_OPENZFS=1
# 용량: 64 ~ 524288 GiB (512 TiB). 기본 10 TiB.
OPENZFS_SIZE_GIB=320
# Throughput (MBps). 허용값: 160 / 320 / 640 / 1280 / 2560 / 3840 / 5120 / 7680 / 10240
OPENZFS_THROUGHPUT=1280


# ─── FSx for NetApp ONTAP (기본 비활성) ─────────────────────────────
# Storage efficiency, 파일 단위 감사, SnapMirror 필요 시 활성화.
ENABLE_ONTAP=0
# 용량: 1024 ~ 1048576 GiB (1 PiB). HA pair × 512 TiB 이하.
ONTAP_SIZE_GIB=10240
# HA pair당 throughput (MBps). 허용값: 1536 / 3072 / 6144
ONTAP_TPUT_PER_HA=3072
# HA pair 수. 1 ~ 12. 각 pair = 6 GBps / 200K IOPS.
ONTAP_HA_PAIRS=1


# ─── License Server (기본 활성) ────────────────────────────
ENABLE_LICENSE_SERVER=1
LICENSE_INSTANCE_TYPE="m7i.large"


# ─── Cluster topology ──────────────────────────────────────────────
# Login Node pool 생성 여부 (Verdi GUI / DCV 용).
# 1: ParallelCluster LoginNodes 풀 생성 (ALB 뒤 multi-user 진입점) — 기본/권장
# 0: on-prem에서 직접 sbatch (Slurm client + munge.key 동기화 필요)
ENABLE_LOGIN_NODE=1

# SSM Session Manager 접속 활성화.
ENABLE_SSM=0


# ─── VPC Endpoints 자동 생성 ───────────────────────────────────────
# ParallelCluster 필수 endpoint를 CDK가 자동 생성합니다.
# 기존에 이미 있는 endpoint는 skip됩니다.
# logs / cloudformation / ec2 / s3 / dynamodb + (LoginNode=1이면) elb / asg
ENABLE_VPC_ENDPOINTS=1


# ─── 선택 ──────────────────────────────────────────────────────────
# CloudWatch alarm 알림 이메일.
# ALARM_EMAIL=""

# 특정 단계만 실행하고 싶을 때:
# SKIP_CDK=0                     # 1이면 CDK 배포 건너뜀 (outputs.json 이미 있을 때)
# SKIP_CLUSTER=0                 # 1이면 pcluster 생성 건너뜀 (config 파일만 생성)
# SKIP_CONNECTIVITY_CHECK=0      # 1이면 subnet 연결성 사전 검증 우회
